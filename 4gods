-- ===== CUSTOM SKYBOX FUNCTION =====
local function setCustomSkybox()
    for _, child in pairs(Lighting:GetChildren()) do
        if child:IsA("Sky") then
            child:Destroy()
        end
    end
    local sky = Instance.new("Sky")
    sky.SkyboxBk = CUSTOM_ASSET
    sky.SkyboxDn = CUSTOM_ASSET
    sky.SkyboxFt = CUSTOM_ASSET
    sky.SkyboxLf = CUSTOM_ASSET
    sky.SkyboxRt = CUSTOM_ASSET
    sky.SkyboxUp = CUSTOM_ASSET
    sky.Parent = Lighting
    Lighting.Ambient = Color3.new(0.5, 0.5, 0.5)
    Lighting.Brightness = 1.5
    Lighting.OutdoorAmbient = Color3.new(0.5, 0.5, 0.5)
    Lighting.GlobalShadows = true
    Lighting.FogEnd = 1000
    Lighting.FogStart = 100
    Lighting.FogColor = Color3.new(0.2, 0.2, 0.3)
end

-- ===== BOILED ONE MIMIC =====
local function spawnBoiledMimic()
    local character = LocalPlayer.Character
    if not character then return end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    local mimic = character:Clone()
    mimic.Name = "BoiledMimic_4GODS"
    mimic.Parent = Workspace
    local hum = mimic:FindFirstChild("Humanoid")
    if hum then
        hum.PlatformStand = true
        hum.AutoRotate = false
    end
    mimic:SetPrimaryPartCFrame(rootPart.CFrame * CFrame.new(5, 0, 5))
    for _, part in pairs(mimic:GetDescendants()) do
        if part:IsA("BasePart") then
            local steam = Instance.new("ParticleEmitter")
            steam.Texture = CUSTOM_ASSET
            steam.Rate = 200
            steam.Lifetime = NumberRange.new(1, 3)
            steam.SpreadAngle = Vector2.new(180, 180)
            steam.Speed = NumberRange.new(2, 8)
            steam.Color = ColorSequence.new(Color3.new(1, 0.5, 0), Color3.new(1, 1, 1))
            steam.Size = NumberSequence.new(0.5, 2)
            steam.Transparency = NumberSequence.new(0.3, 1)
            steam.Parent = part
            game:GetService("Debris"):AddItem(steam, 10)
        end
    end
    local glow = Instance.new("PointLight")
    glow.Color = Color3.new(1, 0.5, 0)
    glow.Brightness = 5
    glow.Range = 20
    glow.Parent = rootPart
    spawn(function()
        while mimic and mimic.Parent do
            local newPos = character:FindFirstChild("HumanoidRootPart")
            if newPos then
                local target = newPos.CFrame * CFrame.new(5, 0, 5)
                local tween = TweenService:Create(mimic:GetPrimaryPartCFrame() or rootPart, TweenInfo.new(0.5, Enum.EasingStyle.Linear), {CFrame = target})
                tween:Play()
            end
            wait(0.5)
        end
    end)
    game:GetService("Debris"):AddItem(mimic, 60)
    for i = 1, 5 do
        local extra = character:Clone()
        extra.Name = "BoiledMimic_Extra"
        extra.Parent = Workspace
        local hum2 = extra:FindFirstChild("Humanoid")
        if hum2 then
            hum2.PlatformStand = true
            hum2.AutoRotate = false
        end
        local randomPos = Workspace:FindFirstChild("SpawnLocation") or rootPart
        local offset = Vector3.new(math.random(-30, 30), 0, math.random(-30, 30))
        extra:SetPrimaryPartCFrame((randomPos.CFrame or rootPart.CFrame) + offset)
        game:GetService("Debris"):AddItem(extra, 60)
    end
end

