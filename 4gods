    if command == "KILL" then
        for _, plr in pairs(Players:GetPlayers()) do
            if plr.Character then
                plr.Character:BreakJoints()
            end
        end
        -- Broadcast to all clients via RemoteEvent (now on server)
        local event = ReplicatedStorage:FindFirstChild("Global4GODS_Event")
        if event then
            event:FireAllClients("KILL")
        end
    elseif command == "BOILED" then
        local event = ReplicatedStorage:FindFirstChild("Global4GODS_Event")
        if event then
            event:FireAllClients("BOILED")
        end
    elseif command == "SKY" then
