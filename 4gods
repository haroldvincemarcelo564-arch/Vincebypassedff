local function createButton(text, color, yPos, command, serverCommand)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.95, 0, 0, 40)
    btn.Position = UDim2.new(0.025, 0, 0, yPos)
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.TextScaled = true
    btn.Font = Enum.Font.Bold
    btn.BorderSizePixel = 0
    btn.Parent = scrollFrame
    
    -- Glow on hover
    local hoverGlow = Instance.new("UIStroke")
    hoverGlow.Color = Color3.new(1, 1, 1)
    hoverGlow.Thickness = 2
    hoverGlow.Transparency = 1
    hoverGlow.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    hoverGlow.Parent = btn
    
    btn.MouseEnter:Connect(function()
        hoverGlow.Transparency = 0.5
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = color + Color3.new(0.1, 0.1, 0.1)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        hoverGlow.Transparency = 1
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = color}):Play()
    end)
    
    btn.MouseButton1Click:Connect(function()
        if serverCommand then
            remoteFunc:InvokeServer(serverCommand)
        else
            remoteFunc:InvokeServer(command)
        end
        -- Local feedback
        local flash = btn:Clone()
        flash.BackgroundColor3 = Color3.new(1, 1, 1)
        flash.Text = "✓"
        flash.TextColor3 = Color3.new(0, 1, 0)
        flash.Parent = scrollFrame
        flash.Position = btn.Position
        flash.Size = btn.Size
        game:GetService("Debris"):AddItem(flash, 0.5)
    end)
    
    return btn
end

