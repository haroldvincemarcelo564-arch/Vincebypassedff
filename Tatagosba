    if flyEnabled and hrp then
        local bv = hrp:FindFirstChildOfClass("BodyVelocity")
        if bv then
            local cam = Workspace.CurrentCamera
            local forward = cam.CFrame.LookVector * (UserInputService:IsKeyDown(Enum.KeyCode.W) and 50 or 0)
            local backward = -cam.CFrame.LookVector * (UserInputService:IsKeyDown(Enum.KeyCode.S) and 50 or 0)
