-- HELPER FUNCTIONS
function addButton(text, callback, parent, y)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, isMobile and 140 or 160, 0, isMobile and 40 or 30)
    btn.Position = UDim2.new(0, isMobile and 5 or 10, 0, y or 0)
    btn.BackgroundColor3 = Color3.fromRGB(60, 10, 10)
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255,200,200)
    btn.TextScaled = true
    btn.Font = Enum.Font.Gotham
    btn.Parent = parent
    btn.BackgroundTransparency = 0
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(80, 20, 20)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(60, 10, 10)}):Play()
    end)
    btn.MouseButton1Click:Connect(callback)
    btn.TouchTap:Connect(callback)
    return btn
end

function addToggle(text, parent, y, default)
    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0, isMobile and 140 or 160, 0, isMobile and 40 or 30)
    toggle.Position = UDim2.new(0, isMobile and 5 or 10, 0, y or 0)
    toggle.BackgroundColor3 = Color3.fromRGB(60, 10, 10)
    toggle.Text = text .. ": OFF"
    toggle.TextColor3 = Color3.fromRGB(255,200,200)
    toggle.TextScaled = true
    toggle.Font = Enum.Font.Gotham
    toggle.Parent = parent
    local state = false
    toggle.MouseEnter:Connect(function()
        TweenService:Create(toggle, TweenInfo.new(0.15), {BackgroundColor3 = Color3.fromRGB(80, 20, 20)}):Play()
    end)
    toggle.MouseLeave:Connect(function()
        TweenService:Create(toggle, TweenInfo.new(0.15), {BackgroundColor3 = state and Color3.fromRGB(40, 180, 40) or Color3.fromRGB(60, 10, 10)}):Play()
    end)
    toggle.MouseButton1Click:Connect(function()
        state = not state
        toggle.Text = text .. ": " .. (state and "ON" or "OFF")
        TweenService:Create(toggle, TweenInfo.new(0.2), {BackgroundColor3 = state and Color3.fromRGB(40, 180, 40) or Color3.fromRGB(60, 10, 10)}):Play()
        callback(state)
    end)
    toggle.TouchTap:Connect(function()
        state = not state
        toggle.Text = text .. ": " .. (state and "ON" or "OFF")
        TweenService:Create(toggle, TweenInfo.new(0.2), {BackgroundColor3 = state and Color3.fromRGB(40, 180, 40) or Color3.fromRGB(60, 10, 10)}):Play()
        callback(state)
    end)
    if default then
        state = true
        toggle.Text = text .. ": ON"
        toggle.BackgroundColor3 = Color3.fromRGB(40, 180, 40)
        callback(true)
    end
    return toggle
end

